{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "publico",
  "title": "Publico",
  "description": "Uma extensão do Raycast para receber as últimas notícias do Público, mantendo-o informado em tempo real diretamente da sua barra de comandos.",
  "icon": "extension-icon.png",
  "author": "caasols",
  "categories": [
    "News"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "latest-headlines",
      "title": "Últimas Notícias",
      "subtitle": "Veja as últimas notícias publicadas",
      "description": "Veja as últimas notícias publicadas",
      "mode": "view"
    },
    {
      "name": "top-news",
      "title": "Destaques",
      "subtitle": "Veja as notícias em destaque",
      "description": "Veja as notícias em destaque",
      "mode": "view"
    },
    {
      "name": "search",
      "title": "Pesquisar Notícias",
      "subtitle": "Pesquise por notícias",
      "description": "Pesquise por notícias",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.95.0",
    "@raycast/utils": "^1.17.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
